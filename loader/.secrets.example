# intel-loader OPTIONAL secrets — copy to .secrets and fill in only if you use keyed feeds.
# This file (.secrets.example) is committed; .secrets must never be committed (see .gitignore).
#
# NONE of these are required by the core MISP -> Wazuh CDB pipeline. misp_to_wazuh.py uses only
# the MISP and Wazuh credentials in .env. These keys are loaded into the container as an optional
# env_file and are reserved for keyed threat-intel feeds / enrichment tooling. If you don't use
# them, leave the values blank or skip creating .secrets entirely (compose treats it as optional).

# AlienVault OTX — https://otx.alienvault.com  (Settings -> API Integration)
OTX_API_KEY=<OTX_API_KEY>

# abuse.ch Auth-Key — https://auth.abuse.ch  (one key covers URLhaus / MalwareBazaar / ThreatFox / Feodo)
ABUSECH_AUTH_KEY=<ABUSECH_AUTH_KEY>

# AbuseIPDB — https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=<ABUSEIPDB_API_KEY>

# GreyNoise Community — https://viz.greynoise.io/account/api-key
GREYNOISE_API_KEY=<GREYNOISE_API_KEY>

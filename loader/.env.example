# intel-loader environment — copy to .env and fill in your values.
# This file (.env.example) is committed; .env must NEVER be committed (see ../.gitignore).

# ---- required: MISP ----
MISP_URL=https://misp-core              # base URL of your MISP instance
ADMIN_KEY=<MISP_AUTH_KEY>               # MISP automation key (Administration -> Auth Keys)

# ---- required: Wazuh ----
WAZUH_API=https://wazuh.manager:55000   # Wazuh manager REST API
WAZUH_USER=wazuh-wui                    # API user
WAZUH_PASS=<WAZUH_API_PASSWORD>         # API password

# ---- export mode ----
# api = portable; pulls indicators via the MISP REST API (/attributes/restSearch). No DB
#       access needed — only MISP_URL + ADMIN_KEY. Recommended for most deployments.
# db  = direct MySQL read; faster for very large MISP instances. Requires the MISP_DB_*
#       vars below, network reach to MISP's database, and the 'pymysql' package.
MISP_EXPORT_MODE=api

# ---- required only when MISP_EXPORT_MODE=db ----
MISP_DB_HOST=db
MISP_DB_USER=misp
MISP_DB_NAME=misp
MISP_DB_PASS=<MISP_DB_PASSWORD>

# ---- manager reload ----
# docker = exec `wazuh-control restart` in the manager container (needs the docker socket
#          mounted and WAZUH_MGR_CONTAINER set). Most reliable.
# api    = call the Wazuh REST restart endpoint (for non-docker / remote deployments).
WAZUH_RELOAD=docker
WAZUH_MGR_CONTAINER=wazuh.manager-1     # docker ps --format '{{.Names}}' | grep wazuh

# ---- tuning (defaults shown) ----
PER_LIST_CAP=200000                     # max IOCs per CDB list (most-recent kept)
MAX_IOC_AGE_DAYS=180                    # ignore indicators older than this
REFRESH_SECONDS=86400                   # loop interval (loop mode)
REFRESH_BATCH=6                         # feeds fetched per batch during staggered refresh
DO_REFRESH=1                            # 0 = skip the MISP feed re-fetch, export only
WL_ENFORCE=1                            # 0 = disable MISP warninglist filtering
# WL_SKIP_LISTS=...                     # ;-separated warninglist names whose hits are KEPT
